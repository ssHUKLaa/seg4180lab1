# Copy this file to .env and fill in your actual values.
# .env is excluded from version control — never commit secrets.

# Flask secret key (used for session signing, CSRF protection, etc.)
FLASK_SECRET_KEY=change-me-to-a-random-string

# Set to "true" for local development, "false" in production
FLASK_DEBUG=false

# Port the app listens on
PORT=5000

# HuggingFace API token — required for private/gated model access.
# Generate one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Path to trained segmentation model checkpoint (produced by train.py)
MODEL_CHECKPOINT=checkpoints/best_model.pth

# Path to the SAM checkpoint file (used by prepare_dataset.py)
# Download: curl -L https://dl.fbaipublicfiles.com/segment_anything/sam_vit_h_4b8939.pth -o sam_vit_h_4b8939.pth
SAM_CHECKPOINT=sam_vit_b_01ec64.pth

# Dataset config: 'mini' (cached) or 'full' (requires Hub access)
DATASET_CONFIG=mini
